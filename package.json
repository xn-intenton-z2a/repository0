{
  "name": "@xn-intenton-z2a/repo",
  "version": "0.1.0",
  "description": "Agentic workflow automation library with CLI and HTTP server capabilities",
  "type": "module",
  "main": "src/lib/main.js",
  "bin": {
    "agentic-repo": "src/lib/main.js"
  },
  "scripts": {
    "build": "echo \"Nothing to build\"",
    "test": "vitest --run tests/unit/*.test.js",
    "test:unit": "vitest --run --coverage tests/unit/*.test.js",
    "start": "node src/lib/main.js",
    "cli": "node src/lib/main.js",
    "serve": "node src/lib/main.js --serve"
  },
  "keywords": [
    "agentic",
    "workflow",
    "automation",
    "cli",
    "github",
    "devops"
  ],
  "author": "Polycode Limited",
  "license": "MIT",
  "dependencies": {
    "@xn-intenton-z2a/agentic-lib": "^7.1.18"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}

{
  "name": "@xn-intenton-z2a/agentic-code-analyzer",
  "version": "1.0.0",
  "description": "An intelligent code analyzer that helps developers understand and improve their JavaScript/Node.js codebases using agentic intelligence",
  "type": "module",
  "main": "src/lib/main.js",
  "bin": {
    "analyze-code": "src/lib/main.js"
  },
  "scripts": {
    "build": "echo \"Nothing to build\"",
    "test": "vitest --run tests/unit/*.test.js",
    "test:unit": "vitest --run --coverage tests/unit/*.test.js",
    "start": "node src/lib/main.js"
  },
  "keywords": [
    "code-analysis",
    "static-analysis",
    "complexity",
    "dependencies",
    "agentic",
    "developer-tools",
    "javascript",
    "nodejs"

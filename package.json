{
  "name": "@xn-intenton-z2a/plot-code-lib",
  "version": "0.1.0",
  "description": "Be the jq of formulae visualisations - transform mathematical expressions to time series data and generate SVG/PNG plots",
  "type": "module",
  "main": "src/lib/main.js",
  "bin": {
    "plot-code-lib": "src/lib/main.js"
  },
  "scripts": {
    "build": "echo \"Nothing to build\"",
    "test": "vitest --run tests/unit/*.test.js",
    "test:unit": "vitest --run --coverage tests/unit/*.test.js",
    "start": "node src/lib/main.js"
  },
  "keywords": ["plotting", "mathematics", "visualization", "cli", "formulae", "time-series"],
  "author": "Polycode Limited",
  "license": "MIT",
  "dependencies": {
    "@xn-intenton-z2a/agentic-lib": "^7.1.28",
    "mathjs": "^14.0.1",
    "commander": "^12.1.0",
    "jsdom": "^25.0.1",
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}

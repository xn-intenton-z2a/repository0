    "@xn-intenton-z2a/agentic-lib": "^7.1.25"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xn-intenton-z2a/repository0.git"
  },

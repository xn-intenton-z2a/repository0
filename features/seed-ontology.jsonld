{
  "@context": {
    "ex": "http://example.org/",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "http://example.org/Animal",
      "@type": "owl:Class",
      "rdfs:label": "Animal"
    },
    {
      "@id": "http://example.org/Mammal",
      "@type": "owl:Class",
      "rdfs:subClassOf": { "@id": "http://example.org/Animal" },
      "rdfs:label": "Mammal"
    },
    {
      "@id": "http://example.org/Dog",
      "@type": "owl:Class",
      "rdfs:subClassOf": { "@id": "http://example.org/Mammal" },
      "rdfs:label": "Dog"
    },
    {
      "@id": "http://example.org/hasFriend",
      "@type": "owl:ObjectProperty",
      "rdfs:domain": { "@id": "http://example.org/Animal" },
      "rdfs:range": { "@id": "http://example.org/Animal" },
      "rdfs:label": "hasFriend"
    },
    {
      "@id": "http://example.org/color",
      "@type": "owl:DatatypeProperty",
      "rdfs:domain": { "@id": "http://example.org/Animal" },
      "rdfs:range": { "@id": "http://www.w3.org/2001/XMLSchema#string" },
      "rdfs:label": "color"
    },
    {
      "@id": "http://example.org/fluffy",
      "@type": "http://example.org/Mammal",
      "http://example.org/color": "brown",
      "http://example.org/hasFriend": { "@id": "http://example.org/buddy" }
    },
    {
      "@id": "http://example.org/buddy",
      "@type": "http://example.org/Dog",
      "http://example.org/color": "brown"
    }
  ]
}

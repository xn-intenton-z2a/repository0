```

### Numeric Range Validation Pattern
```javascript
function check(n) {
  if (!(n >= -500 && n <= 500)) {
    throw new RangeError("The argument must be between -500 and 500.");
  }
}
```

### String Enumeration Validation Pattern  
```javascript
function check(value) {
  if (!["apple", "banana", "carrot"].includes(value)) {
    throw new RangeError(
      'The argument must be an "apple", "banana", or "carrot".'
    );
  }
}
```

### Error Detection Pattern
```javascript
try {
  riskyOperation();
} catch (error) {
  if (error instanceof RangeError) {
    // Handle range-specific errors
    console.log("Range validation failed:", error.message);
  }
}
```

### Array Length Validation Pattern
```javascript
function createArray(length) {
  if (!Number.isInteger(length) || length < 0) {
    throw new RangeError("Array length must be non-negative integer");
  }
  return new Array(length);
}
```

### Configuration Validation Pattern
```javascript
function setConfig(options) {
  const validModes = ["development", "production", "test"];
  if (!validModes.includes(options.mode)) {
    throw new RangeError(
      `Mode must be one of: ${validModes.join(", ")}`
    );
  }
}
```

### Built-in Triggering Examples
```javascript
// Array constructor with invalid length
new Array(-1);  // RangeError: Invalid array length

// Number method with invalid parameters  
(123).toFixed(-1);  // RangeError: toFixed() digits argument must be between 0 and 100

// String normalize with invalid form
"text".normalize("invalid");  // RangeError: Invalid form argument
```

### Custom Range Class Pattern
```javascript
class NumericRange {
  constructor(min, max) {
    this.min = min;
    this.max = max;
  }
  
  validate(value) {
    if (value < this.min || value > this.max) {
      throw new RangeError(
        `Value ${value} outside range [${this.min}, ${this.max}]`
      );
    }
    return value;
  }
}
```


{
  "stringExamples": [
    {
      "input": [
        "karolin",
        "kathrin"
      ],
      "expected": 3,
      "actual": 3,
      "description": "Primary acceptance criteria test case"
    },
    {
      "input": [
        "",
        ""
      ],
      "expected": 0,
      "actual": 0,
      "description": "Empty strings test case"
    },
    {
      "input": [
        "hello",
        "world"
      ],
      "expected": 4,
      "actual": 4,
      "description": "Different characters across string"
    },
    {
      "input": [
        "café",
        "case"
      ],
      "expected": 2,
      "actual": 2,
      "description": "Unicode character support"
    },
    {
      "input": [
        "🚀🌟",
        "🚀🎉"
      ],
      "expected": 1,
      "actual": 1,
      "description": "Emoji support with surrogate pairs"
    }
  ],
  "bitsExamples": [
    {
      "input": [
        1,
        4
      ],
      "expected": 2,
      "actual": 2,
      "description": "Primary acceptance criteria test case (001 vs 100)",
      "binary": {
        "x": "001",
        "y": "100"
      }
    },
    {
      "input": [
        0,
        0
      ],
      "expected": 0,
      "actual": 0,
      "description": "Identical integers test case",
      "binary": {
        "x": "0",
        "y": "0"
      }
    },
    {
      "input": [
        7,
        4
      ],
      "expected": 2,
      "actual": 2,
      "description": "Multiple bit differences",
      "binary": {
        "x": "111",
        "y": "100"
      }
    },
    {
      "input": [
        5,
        3
      ],
      "expected": 2,
      "actual": 2,
      "description": "Mixed bit pattern",
      "binary": {
        "x": "101",
        "y": "011"
      }
    },
    {
      "input": [
        15,
        0
      ],
      "expected": 4,
      "actual": 4,
      "description": "All bits different in 4-bit pattern",
      "binary": {
        "x": "1111",
        "y": "0000"
      }
    }
  ]
}